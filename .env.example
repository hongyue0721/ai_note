# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_NAME=StarGraph AI
JWT_SECRET=replace-with-long-random-jwt-secret
ADMIN_JWT_SECRET=replace-with-long-random-admin-jwt-secret
CORS_ORIGINS=http://localhost:3000

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stargraph
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-db-password
# Prefer POSTGRES_* as the single source of truth in deployment.
# DATABASE_URL should be derived from the same values to avoid credential drift.
DATABASE_URL=postgresql+psycopg://postgres:replace-with-strong-db-password@localhost:5432/stargraph

# Storage
STORAGE_PROVIDER=local
UPLOADS_ROOT_DIR=data/uploads
UPLOADS_URL_BASE=/uploads
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=stargraph-dev
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=

# AI
GEMINI_API_KEY=
GEMINI_MODEL_EXTRACT=gemini-2.0-flash
GEMINI_MODEL_SOLVE=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_CLASSIFY=gpt-4.1-mini
OPENAI_MODEL_SOLVE=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=60

# Seed
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=replace-with-strong-admin-password
SEED_ADMIN_DISPLAY_NAME=System Admin
